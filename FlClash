# 锚点 - 节点订阅的参数 [每小时更新一次订阅节点，每 6 秒一次健康检查]
NodeParam: &NodeParam {type: http, interval: 3600, health-check: {enable: true, url: 'https://cp.cloudflare.com/generate_204', interval: 300}}

# 锚点 - 节点订阅
proxy-providers: 
  良心云:
    url: "订阅链接"
    <<: *NodeParam
    proxy: "DIRECT"
    path: './proxy_providers/良心云.yaml'
    exclude-filter: "群|邀请|返利|官网|过期|流量|剩余|官网|备用" # 提前过滤垃圾节点
    override:
      additional-prefix: "良心-" # 为订阅节点添加机场名称前缀
      skip-cert-verify: true
      udp: true 
  Hneko云:
    url: "订阅链接"
    <<: *NodeParam
    proxy: "DIRECT"
    path: './proxy_providers/Hneko云.yaml'
    exclude-filter: "群|邀请|返利|官网|过期|流量|剩余|官网|备用" # 提前过滤垃圾节点
    override:
      additional-prefix: "备用-" # 为订阅节点添加机场名称前缀
      skip-cert-verify: true
      udp: true 

proxies:



mixed-port: 7892

unified-delay: true
geodata-mode: true
geodata-loader: memconservative
geo-auto-update: true
geo-update-interval: 24
tcp-concurrent: true
find-process-mode: strict
global-client-fingerprint: chrome

allow-lan: true
mode: rule
log-level: info
ipv6: true
udp: true

external-controller: 0.0.0.0:9090
# external-ui: ui
# external-ui-url: 'https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip'

geox-url:
  geoip: 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geoip.dat'
  geosite: 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geosite.dat'
  mmdb: 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/country.mmdb'
  asn: 'https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/GeoLite2-ASN.mmdb'

profile:
  store-selected: true
  store-fake-ip: true
  restore-dns: true          # 退出自动恢复 DNS
  auto-direct-on-exit: true  # 退出软件自动恢复直连

sniffer:
  enable: true
  parse-pure-ip: true  # 处理纯 IP 请求
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]
  skip-domain:
    - "Mijia Cloud"
    - "+.push.apple.com"
  skip-src-address:
    - 192.168.1.0/24
  skip-dst-address:
    # telegram ip
    - 91.105.192.0/23
    - 91.108.4.0/22
    - 91.108.8.0/21
    - 91.108.16.0/21
    - 91.108.56.0/22
    - 95.161.64.0/20
    - 149.154.160.0/20
    - 185.76.151.0/24
    - 2001:67c:4e8::/48
    - 2001:b28:f23c::/47
    - 2001:b28:f23f::/48
    - 2a0a:f280:203::/48

tun:
  enable: true
  stack: mixed
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true


dns:
  enable: true
  cache-algorithm: arc
  listen: 0.0.0.0:1053
  ipv6: false
  respect-rules: true
  use-hosts: true
  use-system-hosts: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - rule-set:fakeipfilter
  nameserver:
    - https://223.5.5.5/dns-query
    - https://doh.pub/dns-query
  proxy-server-nameserver:
    - https://223.5.5.5/dns-query
    - https://doh.pub/dns-query
  

# 锚点 - 节点筛选组
FilterHK: &FilterHK '^(?=.*((?i)🇭🇰|香港|(\b(HK|HKG|Hong)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterTW: &FilterTW '^(?=.*((?i)🇹🇼|台湾|(\b(TW|TWN|Tai|Taiwan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterJP: &FilterJP '^(?=.*((?i)🇯🇵|日本|川日|东京|大阪|泉日|埼玉|(\b(JP|JPN|Japan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterKR: &FilterKR '^(?=.*((?i)🇰🇷|韩国|韓|首尔|(\b(KR|KOR|Korea)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterSG: &FilterSG '^(?=.*((?i)🇸🇬|新加坡|狮|(\b(SG|SGP|Singapore)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterUS: &FilterUS '^(?=.*((?i)🇺🇸|美国|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|阿什本|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|(\b(US|USA|United States)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterUK: &FilterUK '^(?=.*((?i)🇬🇧|英国|伦敦|(\b(UK|GBR|United Kingdom)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterFR: &FilterFR '^(?=.*((?i)🇫🇷|法国|(\b(FR|FRA|France)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterDE: &FilterDE '^(?=.*((?i)🇩🇪|德国|(\b(DE|DEU|Germany)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterAll: &FilterAll '^(?=.*(.))(?!.*((?i)群|邀请|返利|循环|官网|客服|网站|网址|获取|订阅|流量|到期|机场|下次|版本|官址|备用|过期|已用|联系|邮箱|工单|贩卖|通知|倒卖|防止|国内|地址|频道|无法|说明|使用|提示|特别|访问|支持|教程|关注|更新|作者|加入|超时|收藏|福利|邀请|好友|失联|(\b(USE|USED|TOTAL|EXPIRE|EMAIL|Panel|Channel|Author|Traffic)(\d+)?\b|(\d{4}-\d{2}-\d{2}|\dG)))).*$'

# 策略组参数锚点
Select: &Select {type: select, proxies: [HongKong, TaiWan, Japan, Singapore, America]}
# 锚点 - 时延优选参数 [每 6 秒一次惰性健康检查，容差 20ms，时延超过 2 秒判定为失败，失败 3 次则自动触发健康检查]
UrlTest: &UrlTest {type: url-test, interval: 6, tolerance: 20, lazy: true, url: 'https://cp.cloudflare.com/generate_204', disable-udp: false, timeout: 2000, max-failed-times: 3, hidden: true, include-all-providers: true}
# 锚点 - 故障转移参数 [每 6 秒一次惰性健康检查，时延超过 2 秒判定为失败，失败 3 次则自动触发健康检查]
FallBack: &FallBack {type: fallback, interval: 6, lazy: true, url: 'https://cp.cloudflare.com/generate_204', disable-udp: false, timeout: 2000, max-failed-times: 3, hidden: true, include-all-providers: true}
# 锚点 - 负载均衡参数 [每 6 秒一次惰性健康检查，时延超过 2 秒判定为失败，失败 3 次则自动触发健康检查]
LoadBalance: &LoadBalance {type: load-balance, interval: 6, lazy: true, url: 'https://cp.cloudflare.com/generate_204', disable-udp: false, strategy: consistent-hashing, timeout: 2000, max-failed-times: 3, hidden: true, include-all-providers: true}
# 锚点 - 规则参数 [每小时更新一次订阅规则，更新规则时使用直连策略]
class: &class {type: http, behavior: classical, interval: 3600, format: text, proxy: DIRECT}
domain: &domain {type: http, behavior: domain, interval: 3600, format: mrs, proxy: DIRECT}
ip: &ip {type: http, behavior: ipcidr, interval: 3600, format: mrs, proxy: DIRECT}


# 策略组
proxy-groups: 
  - {name: Final, <<: *Select, icon: https://gh-proxy.com/https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Final.png}
  - {name: Google, type: select, proxies: [HongKong, TaiWan, Japan, Singapore, America], icon: https://raw.githubusercontent.com/Koolson/Qure/refs/heads/master/IconSet/Color/Google.png}
  - {name: HongKong, type: select, proxies: [HK-Auto, HK-FallBack], include-all-providers: true, filter: *FilterHK, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Hong_Kong.png}
  - {name: TaiWan, type: select, proxies: [TW-Auto, TW-FallBack], include-all-providers: true, filter: *FilterTW, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Taiwan.png}
  - {name: Japan, type: select, proxies: [JP-Auto, JP-FallBack], include-all-providers: true, filter: *FilterJP, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Japan.png}
  - {name: Singapore, type: select, proxies: [SG-Auto, SG-FallBack], include-all-providers: true, filter: *FilterSG, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Singapore.png}
#  - {name: Korea, type: select, proxies: [KR-Auto, KR-FallBack,], include-all-providers: true, filter: *FilterKR, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Korea.png}
  - {name: America, type: select, proxies: [US-Auto, US-FallBack], include-all-providers: true, filter: *FilterUS, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/United_States.png}
# 全部节点
  - {name: AllServer, type: select, proxies: [All-Auto], include-all-providers: true, filter: *FilterAll, icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Clubhouse.png}

# 延时优选代理组
  - {name: HK-Auto, <<: *UrlTest, filter: *FilterHK}
  - {name: TW-Auto, <<: *UrlTest, filter: *FilterTW}
  - {name: JP-Auto, <<: *UrlTest, filter: *FilterJP}
  - {name: SG-Auto, <<: *UrlTest, filter: *FilterSG}
  - {name: KR-Auto, <<: *UrlTest, filter: *FilterKR}
  - {name: US-Auto, <<: *UrlTest, filter: *FilterUS}

# 故障转移代理组
  - {name: HK-FallBack, <<: *FallBack, filter: *FilterHK}
  - {name: TW-FallBack, <<: *FallBack, filter: *FilterTW}
  - {name: JP-FallBack, <<: *FallBack, filter: *FilterJP}
  - {name: SG-FallBack, <<: *FallBack, filter: *FilterSG}
  - {name: KR-FallBack, <<: *FallBack, filter: *FilterKR}
  - {name: US-FallBack, <<: *FallBack, filter: *FilterUS}

# 负载均衡代理组
# - {name: HK-LoadBalance, <<: *LoadBalance, filter: *FilterHK}
# - {name: TW-LoadBalance, <<: *LoadBalance, filter: *FilterTW}
# - {name: JP-LoadBalance, <<: *LoadBalance, filter: *FilterJP}
# - {name: SG-LoadBalance, <<: *LoadBalance, filter: *FilterSG}
# - {name: KR-LoadBalance, <<: *LoadBalance, filter: *FilterKR}
# - {name: US-LoadBalance, <<: *LoadBalance, filter: *FilterUS}

# 全部节点延时优选
  - {name: All-Auto, <<: *UrlTest, filter: *FilterAll}

# 规则指向
rules:
 # 【云元数据服务】WSL2/本地环境不可达，直接拒绝避免无意义的连接尝试
  - IP-CIDR,169.254.169.254/32,REJECT,no-resolve
  # windows 的天气等小组件使用的 cdn, 同样因为无法连接导致日志刷屏, 故禁用
  - DOMAIN,t-ring-fdv2.msedge.net,REJECT,no-resolve

  # 【DNS 服务器】确保 DNS 请求正确路由
  - IP-CIDR,223.5.5.5/32,直连,no-resolve       # 阿里 DNS
  - IP-CIDR,223.6.6.6/32,直连,no-resolve       # 阿里 DNS 备用
  - RULE-SET,private_ip,DIRECT,no-resolve
  - RULE-SET,private,DIRECT
  
  
  - RULE-SET,google,Google
  - RULE-SET,telegram,Final
  - RULE-SET,google_ip,Google
  - RULE-SET,telegram_ip,Final
  
  - RULE-SET,cn,DIRECT
  - RULE-SET,cn_ip,DIRECT,no-resolve
  
  - RULE-SET,geolocation-!cn_domain,Final
  - MATCH, Final

# 订阅规则
