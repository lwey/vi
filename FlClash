profile:
  store-selected: true
  store-fake-ip: true
  restore-dns: true          # 退出自动恢复 DNS
  auto-direct-on-exit: true  # 退出软件自动恢复直连

sniffer:
  enable: true
  force-dns-mapping: true
  parse-pure-ip: true
  override-destination: true
  sniff:
    TLS:
      ports: [443, 8443]
    HTTP:
      ports: [80, 8080-8880]
    QUIC:
      ports: [443, 8443]
  force-domain:
    - +.netlify.app
    - +.vercel.app
    - +.workers.dev
  skip-domain:
    - +.mijia.cloud
    - +.oray.com
    - +.oray.net
    - +.apple.com

tun:
  enable: true
  stack: mixed
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true


dns:
