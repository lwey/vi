# ====================================================
#  Mihomo (Clash Meta) 配置文件
#  特点：双核心去广告 + 精准分流 + 策略组图标
#  更新：订阅每日更新，规则每日更新
# ====================================================

#---------------------------------------------------#
## 锚点 - 全局参数定义
#---------------------------------------------------#

# 节点订阅参数 [每日更新，每6秒健康检查]
NodeParam: &NodeParam
  type: http
  interval: 86400
  health-check:
    enable: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 6

# 地区筛选正则
FilterHK: &FilterHK '^(?=.*((?i)🇭🇰|香港|(\b(HK|HKG|Hong)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterTW: &FilterTW '^(?=.*((?i)🇹🇼|台湾|(\b(TW|TWN|Tai|Taiwan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterJP: &FilterJP '^(?=.*((?i)🇯🇵|日本|川日|东京|大阪|泉日|埼玉|(\b(JP|JPN|Japan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterSG: &FilterSG '^(?=.*((?i)🇸🇬|新加坡|狮|(\b(SG|SGP|Singapore)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'
FilterUS: &FilterUS '^(?=.*((?i)🇺🇸|美国|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|(\b(US|USA|United States)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$'

# 代理组类型参数
Select: &Select {type: select, proxies: [HongKong, TaiWan, Japan, Singapore, America]}
UrlTest: &UrlTest {type: url-test, interval: 6, tolerance: 20, lazy: true, url: 'http://www.gstatic.com/generate_204', timeout: 2000, max-failed-times: 3, hidden: true, include-all-providers: true}
FallBack: &FallBack {type: fallback, interval: 6, lazy: true, url: 'http://www.gstatic.com/generate_204', timeout: 2000, max-failed-times: 3, hidden: true, include-all-providers: true}

# 规则集参数 [每日更新]
RuleSet_domain_mrs: &RuleSet_domain_mrs {type: http, behavior: domain, interval: 86400, format: mrs, proxy: DIRECT}
RuleSet_ipcidr_mrs: &RuleSet_ipcidr_mrs {type: http, behavior: ipcidr, interval: 86400, format: mrs, proxy: DIRECT}

#---------------------------------------------------#
## 端口与基本设置
#---------------------------------------------------#
port: 7890
socks-port: 7891
mixed-port: 7892
allow-lan: true
mode: rule
log-level: info
ipv6: true
udp: true
unified-delay: true
geodata-mode: false
geodata-loader: standard
geo-auto-update: true
geo-update-interval: 24
tcp-concurrent: true
find-process-mode: strict
global-client-fingerprint: chrome

# API 控制 (务必修改 secret)
external-controller: 0.0.0.0:9090
secret: "ChangeThisSecretPlease123"

# 地理数据库
geox-url:
  geoip: 'https://raw.githubusercontent.com/Loyalsoldier/v2ray-rules-dat/release/geoip.dat'
  geosite: 'https://raw.githubusercontent.com/Loyalsoldier/v2ray-rules-dat/release/geosite.dat'
  mmdb: 'https://geodata.kelee.one/Country-Masaiki.mmdb'

profile:
  store-selected: true
  store-fake-ip: true

sniffer:
  enable: true
  force-dns-mapping: true
  parse-pure-ip: true
  override-destination: true
  sniff:
    HTTP: {ports: [80, 8080-8880], override-destination: true}
    TLS: {ports: [443, 8443]}
    QUIC: {ports: [443, 8443]}
  skip-domain: ["Mijia Cloud", "*.push.apple.com", "*.oray.com", "*.sunlogin.net"]

tun:
  enable: true
  stack: mixed
  dns-hijack: [any:53, "tcp://any:53"]
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true

#---------------------------------------------------#
## DNS 配置
#---------------------------------------------------#
dns:
  enable: true
  prefer-h3: true
  listen: 0.0.0.0:1053
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 28.0.0.1/8
  fake-ip-filter-mode: blacklist
  default-nameserver:
    - https://223.5.5.5/dns-query
  proxy-server-nameserver:
    - https://dns.alidns.com/dns-query
  direct-nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query
  nameserver:
    - https://8.8.8.8/dns-query#ecs=223.5.5.0/24
    - https://1.1.1.1/dns-query#ecs=223.5.5.0/24
  fallback:
    - tls://8.8.4.4
  fake-ip-filter:
    - "rule-set:fakeipfilter_domain"

#---------------------------------------------------#
## 节点订阅
#---------------------------------------------------#
proxy-providers:
  Hneko云:
    url: '机场1的订阅URL'   # ⚠️ 请替换为你的订阅链接
    <<: *NodeParam
    proxy: DIRECT
    path: './proxy_providers/Hneko云.yaml'
    exclude-filter: "群|邀请|返利|官网|过期|流量|剩余|备用|客服|网址"
    override:
      additional-prefix: "Hneko-"
      skip-cert-verify: true
      udp: true
      
  良心云:
    url: 'https://liangxin.xyz/api/v1/liangxin?OwO=5ea97947e4ed644de14065f8e72a5655'   # ⚠️ 请替换为你的订阅链接
    <<: *NodeParam
    proxy: DIRECT
    path: './proxy_providers/良心云.yaml'
    exclude-filter: "群|邀请|返利|官网|过期|流量|剩余|备用|客服|网址"
    override:
      additional-prefix: "良心云-"
      skip-cert-verify: true
      udp: true

# 本地静态代理
proxies:

#---------------------------------------------------#
## 代理组 (带图标)
#---------------------------------------------------#
proxy-groups:
  # --- 顶级策略组 ---
  - name: Final
    <<: *Select
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Final.png"

  - name: ChatGPT
    type: select
    proxies: [HongKong, TaiWan, Japan, Singapore, America]
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/ChatGPT.png"

  - name: Google
    type: select
    proxies: [HongKong, TaiWan, Japan, Singapore, America]
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Google.png"

  - name: 广告拦截
    type: select
    proxies: [REJECT, REJECT-DROP, PASS]
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Adblock.png"

  # --- 地区手动选择组 ---
  - name: HongKong
    type: select
    proxies: [HK-Auto, HK-FallBack]
    include-all-providers: true
    filter: *FilterHK
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Hong_Kong.png"

  - name: TaiWan
    type: select
    proxies: [TW-Auto, TW-FallBack]
    include-all-providers: true
    filter: *FilterTW
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Taiwan.png"

  - name: Japan
    type: select
    proxies: [JP-Auto, JP-FallBack]
    include-all-providers: true
    filter: *FilterJP
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Japan.png"

  - name: Singapore
    type: select
    proxies: [SG-Auto, SG-FallBack]
    include-all-providers: true
    filter: *FilterSG
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Singapore.png"

  - name: America
    type: select
    proxies: [US-Auto, US-FallBack]
    include-all-providers: true
    filter: *FilterUS
    icon: "https://fastly.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/United_States.png"

  # --- 自动测速组 (隐藏，无图标) ---
  - name: HK-Auto
    <<: *UrlTest
    filter: *FilterHK

  - name: TW-Auto
    <<: *UrlTest
    filter: *FilterTW

  - name: JP-Auto
    <<: *UrlTest
    filter: *FilterJP

  - name: SG-Auto
    <<: *UrlTest
    filter: *FilterSG

  - name: US-Auto
    <<: *UrlTest
    filter: *FilterUS

  # --- 故障转移组 (隐藏，无图标) ---
  - name: HK-FallBack
    <<: *FallBack
    filter: *FilterHK

  - name: TW-FallBack
    <<: *FallBack
    filter: *FilterTW

  - name: JP-FallBack
    <<: *FallBack
    filter: *FilterJP

  - name: SG-FallBack
    <<: *FallBack
    filter: *FilterSG

  - name: US-FallBack
    <<: *FallBack
    filter: *FilterUS

#---------------------------------------------------#
## 分流规则
#---------------------------------------------------#
rules:
  # 1. 去广告 (核心)
  - RULE-SET, QiuFeng, 广告拦截
  - RULE-SET, AdBlock_Reject, 广告拦截

  # 2. 本地/私有网络直连
  - RULE-SET, private_ip, DIRECT, no-resolve
  - RULE-SET, private_domain, DIRECT

  # 3. 国内域名直连
  - RULE-SET, cn_domain, DIRECT
  - RULE-SET, geolocation-cn, DIRECT

  # 4. 特定服务
  - RULE-SET, ai, ChatGPT
  - RULE-SET, youtube_domain, Final
  - RULE-SET, google_domain, Google
  - RULE-SET, github_domain, Final
  - RULE-SET, microsoft_domain, Final
  - RULE-SET, apple_domain, DIRECT
  - RULE-SET, telegram_domain, Final

  # 5. 非中国域名代理
  - RULE-SET, geolocation-!cn, Final

  # 6. IP规则
  - RULE-SET, apple_ip, DIRECT
  - RULE-SET, google_ip, Google
  - RULE-SET, telegram_ip, Final
  - RULE-SET, cn_ip, DIRECT

  # 7. 兜底
  - MATCH, Final

#---------------------------------------------------#
## 规则集订阅
#---------------------------------------------------#
rule-providers:
