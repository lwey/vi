# 订阅规则
rule-providers:

  adblock:
    <<: *RuleSet_domain_mrs
    format: mrs
    url: 'https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@meta/geo/geosite/category-ads-all.mrs'

  Tracking:       {<<: *RuleSet_domain_mrs, url: https://github.com/666OS/rules/raw/release/mihomo/domain/Tracking.mrs}
  Advertising:    {<<: *RuleSet_domain_mrs, url: https://github.com/666OS/rules/raw/release/mihomo/domain/Advertising.mrs} 
  AdvertisingIP:  {<<: *RuleSet_ipcidr_mrs, url: https://github.com/666OS/rules/raw/release/mihomo/ip/Advertising.mrs}


  秋风广告规则:
    <<: *RuleProviders
    path: ./rule_providers/AWAvenue-Ads-Rule-Clash.yaml
    url: "https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/refs/heads/main/Filters/AWAvenue-Ads-Rule-Clash-Classical.yaml"

  AI:
    <<: *RuleProviders
    path: './rules/AI.yaml'
    url: 'https://kelee.one/Tool/Clash/Rule/AI.yaml'

  youtube:
    <<: *RuleSet_domain_mrs
    format: mrs
    url: 'https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@meta/geo/geosite/youtube.mrs'


# 规则指向
rules:
  - RULE-SET, 秋风广告规则, 广告拦截
  - RULE-SET, adblock, 广告拦截
  - RULE-SET,Tracking,广告拦截
  - RULE-SET,Advertising,广告拦截
  - AND,((DST-PORT,443),(NETWORK,UDP),(NOT,((GEOIP,CN)))),广告拦截  # 阻止海外 QUIC
  # 阻断 YouTube UDP 流量
  - AND,((NETWORK,UDP),(DST-PORT,443),(RULE-SET,youtube)),广告拦截
  - RULE-SET,AdvertisingIP,广告拦截,no-resolve
  - GEOIP,lan,直连,no-resolve
  - GEOSITE,github,Final
  - GEOSITE,twitter,Final
  - GEOSITE,youtube,Final
  - GEOSITE,google,Google
  - GEOSITE,telegram,Final
  - GEOSITE,CN,直连
  - GEOSITE,geolocation-!cn,Final
  - RULE-SET, AI, ChatGPT
  - GEOIP,google,Google
  - GEOIP,telegram,Final
  - GEOIP,twitter,Final
  - GEOIP, CN, 直连
  - MATCH, Final
