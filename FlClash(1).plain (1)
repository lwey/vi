sniffer:
  enable: true                       
  force-dns-mapping: true            
  parse-pure-ip: true               
  override-destination: true         

  sniff:
    HTTP:
      ports: [80, 8080-8880]         
      override-destination: true     
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]
  force-domain:                      
    - +.v2ex.com
  skip-domain:                       
    - Mijia Cloud
  skip-src-address:
    - 192.168.1.1/24
  skip-dst-address:
    - 91.105.192.0/23
    - 91.108.4.0/22
    - 91.108.8.0/21
    - 91.108.16.0/21
    - 91.108.56.0/22
    - 95.161.64.0/20
    - 149.154.160.0/20
    - 185.76.151.0/24
    - 169.254.169.254/32
    - 2001:67c:4e8::/48
    - 2001:b28:f23c::/47
    - 2001:b28:f23f::/48
    - 2a0a:f280:203::/48

tun:
  enable: true
  # system/gvisor/mixed
  stack: system
  dns-hijack: ["any:53", "tcp://any:53"]
  mtu: 1500
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true

dns:
  enable: true
  cache-algorithm: arc
  listen: 0.0.0.0:1053
  ipv6: false
  respect-rules: true
  use-hosts: true
  use-system-hosts: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - "*"
    - +.lan
  # 用于解析「DNS 服务器自身域名」，以及 Mihomo 启动初期的基础解析。
  default-nameserver:
    - 223.5.5.5                         # 阿里 UDP
    - 119.29.29.29                      # 腾讯 Pod 备用
  # 解析「代理服务器域名」，防止 nameserver 无法访问导致连不上代理
  proxy-server-nameserver:
    - 223.5.5.5                         # 阿里 UDP
    - 119.29.29.29                      # 腾讯 Pod 备用
  # 「直连」域名的解析
  direct-nameserver:
    - https://dns.alidns.com/dns-query # 阿里 DoH
    - https://doh.pub/dns-query        # 腾讯 DNSPod DoH
  # 用来解析没有匹配到任何「域名规则」的域名，通常是国外域名，建议使用国外 DoH 防止污染。
  # 但这个解析结果并不会用来发起连接，所以为了追求速度不使用 DoH 或直接使用国内 DNS 也行。
  # 所以保持国内 DoQ/DoH 作为主解析最可靠
  nameserver:
    - https://dns.alidns.com/dns-query # 阿里 DoH
    - https://doh.pub/dns-query        # 腾讯 DNSPod DoH

